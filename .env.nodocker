# API Keys (Required)
OPENAI_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here
GOOGLE_API_KEY=your_key_here

# Database (SQLite - No Postgres required)
USE_SQLITE=true
DATABASE_URL=sqlite:///data/pca_agent.db

# Redis (Disabled - No Redis required)
REDIS_ENABLED=false
# If you install Redis natively later, set to true and:
# REDIS_URL=redis://localhost:6379/0

# Knowledge Graph (Neo4j - NATIVE INSTALLATION REQUIRED)
# You must install Neo4j Desktop or Server manually
KG_NEO4J_URI=bolt://localhost:7687
KG_NEO4J_USER=neo4j
KG_NEO4J_PASSWORD=password

# Storage
UPLOAD_DIR=./data/uploads
REPORT_DIR=./data/reports
SNAPSHOT_DIR=./data/snapshots

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# JWT Authentication
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Client Config
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Model Config
DEFAULT_LLM_MODEL=gpt-4-turbo-preview
